# Carpeta de archivos locales (config con secretos, caché, logs, notas).
# Se ignora todo el contenido salvo el README marcador.
local/*
!local/README.md

# Carpeta de entrada (imágenes crudas de ejercicios subidos por alumnos).
# JAMAS deben llegar al repo publico. Solo se versiona el README marcador.
entrada/*
!entrada/README.md

# Sistema operativo
Thumbs.db
Desktop.ini
.DS_Store

# Editores
.vscode/
.idea/
*.swp

# Configuración de MCPs (puede contener tokens) — nunca commitear.
.mcp.json

# Archivos efímeros del tablero — snapshots de Drive y cola de procesado.
# Estos pueden contener referencias a imágenes con datos del alumno.
tablero/datos.json
tablero/cola.json
tablero/estado.json
tablero/refresh.json
tablero/eliminados.json
tablero/thumbs/
